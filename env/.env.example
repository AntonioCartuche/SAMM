# Copiar a env/.env y ajustar valores.
#
# ── Opción A: ejecutas solo `npm start` en tu PC y Postgres está en Docker Compose ──
# Usa localhost y el PUERTO PUBLICADO del compose (por defecto 35417), no DB_HOST=postgres.
DB_HOST=localhost
DB_PORT=35417
DB_USER=samm
DB_PASSWORD=samm_dev_pass
DB_DATABASE=samm
#
# ── Opción B: Postgres instalado localmente en el puerto estándar ──
# DB_HOST=localhost
# DB_PORT=5432
#
# ── Opción C: dentro del contenedor `app` en Docker ──
# Compose ya define DB_HOST=postgres y DB_PORT=5432; no necesitas env/.env en la imagen.

SESSION_SECRET=cambia-esto-en-produccion

# Si sigues viendo mensajes dotenv extra en la consola, puedes usar:
# DOTENV_CONFIG_QUIET=true
